# Domain / TLS
# Use an existing domain you already own (only a subdomain is needed), e.g.
#   portal.iidmage.fr  OR  portal.iidmage.com  OR  suivi.iidmage.fr
DOMAIN=portal.your-domain.tld
LETSENCRYPT_EMAIL=admin@iidmage.com

# Postgres (container)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB=iidmage

# Backend connection string (container network)
DATABASE_URL=postgresql://postgres:change_me@db:5432/iidmage

# Backend security
JWT_SECRET=change_me_to_a_long_random_secret

# Frontend origin (same domain)
FRONTEND_URL=https://portal.your-domain.tld
CORS_ORIGIN=https://portal.your-domain.tld

# Seed admin (first run)
ADMIN_EMAIL=admin@iidmage.com
ADMIN_PASSWORD=change_me

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

{
  email {$LETSENCRYPT_EMAIL}
}

{$DOMAIN} {
  encode gzip

  # Backend API (strip /api prefix)
  handle_path /api/* {
    reverse_proxy backend:4000
  }

  # Serve uploaded files from backend
  handle /uploads/* {
    reverse_proxy backend:4000
  }

  # Frontend (Next.js)
  handle {
    reverse_proxy frontend:3000
  }
}
